# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# --- GitHub token (required for traffic, actions, community standards) ---
# Create a fine-grained PAT at: https://github.com/settings/personal-access-tokens
# Needs "Contents: read" and "Metadata: read" for the target repo.
# Must have the same scopes as the OSS_DASHBOARD_GITHUB_TOKEN secret used in CI.
OSS_DASHBOARD_GITHUB_TOKEN=ghp_your_token_here

# --- GoatCounter analytics (required if documentation_analytics is enabled) ---
GOATCOUNTER_API_KEY=your_goatcounter_api_key
GOATCOUNTER_SITE_URL=https://your-site.goatcounter.com
GOATCOUNTER_TRACKED_DOMAIN=your-docs-domain.example.org

# --- Vite base path (set to match GitHub Pages URL) ---
# For a repo named "oss-impact-dashboard", use /oss-impact-dashboard/
VITE_BASE_PATH=/oss-impact-dashboard/
