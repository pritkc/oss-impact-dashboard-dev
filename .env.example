# Copy to .env — never commit this file.
# Setup details: docs/GETTING_STARTED.md

# Naming: project id "example" → GH_PAT_EXAMPLE, GOATCOUNTER_API_KEY_EXAMPLE
#         project id "mole-local" → GH_PAT_MOLE_LOCAL, etc.

# Generic starting point
GH_PAT_EXAMPLE=
GOATCOUNTER_API_KEY_EXAMPLE=

# MOLE deployment (this repo)
GH_PAT_MOLE=
GOATCOUNTER_API_KEY_MOLE=
RTD_USERNAME_MOLE=
RTD_PASSWORD_MOLE=
RTD_TOTP_SECRET_MOLE=
GH_PAT_MOLE_LOCAL=
GOATCOUNTER_API_KEY_MOLE_LOCAL=
