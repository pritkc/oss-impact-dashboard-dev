{
  "name": "oss-impact-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:pages": "GITHUB_ACTIONS=true GITHUB_REPOSITORY=pritkc/oss-impact-dashboard-dev VITE_BASE_PATH=/oss-impact-dashboard-dev/ vite build",
    "preview": "vite preview --host 127.0.0.1",
    "preview:pages": "GITHUB_REPOSITORY=pritkc/oss-impact-dashboard-dev VITE_BASE_PATH=/oss-impact-dashboard-dev/ node scripts/preview-pages.mjs",
    "test:frontend": "node web/tests/smoke.mjs && node web/tests/security.mjs",
    "test:build": "GITHUB_REPOSITORY=${GITHUB_REPOSITORY:-pritkc/oss-impact-dashboard-dev} VITE_BASE_PATH=${VITE_BASE_PATH:-/oss-impact-dashboard-dev/} node web/tests/postbuild.mjs",
    "test:e2e": "npm run test:build && node web/tests/smoke.mjs && node web/tests/security.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "tabulator-tables": "^6.3.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "jsdom": "^27.3.0"
  }
}
